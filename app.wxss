/* app.wxss - 全局样式（梦幻治愈·马卡龙） */

page {
  --color-pink: #FFD3DA;
  --color-cream: #FFF4D6;
  --color-mint: #C8E6D9;
  --color-sky: #D6E5F5;
  --color-lavender: #E5D9F2;
  --color-peach: #FFD9B3;
  --color-text: #5A5A6E;
  --color-subtext: #9999A8;
  --color-bg: #FFFCF7;
  --color-card: #FFFFFF;
  --color-primary: #FF9FB0;
  --color-primary-soft: #FFE3E8;
  --color-accent: #B4D8C7;
  --color-warn: #FFB6A3;

  --shadow-soft: 0 8rpx 24rpx rgba(255, 200, 200, 0.18);
  --shadow-card: 0 4rpx 16rpx rgba(180, 180, 200, 0.10);
  --shadow-float: 0 12rpx 32rpx rgba(255, 159, 176, 0.25);

  --radius-sm: 16rpx;
  --radius-md: 24rpx;
  --radius-lg: 32rpx;
  --radius-full: 9999rpx;

  /* v3.1 · 5 大食物类别色（CSS 变量供 WXSS 引用） */
  --cat-staple-bg:  #FFE7A0;
  --cat-veggie-bg:  #C6EBC9;
  --cat-protein-bg: #FFC7A0;
  --cat-soup-bg:    #C7E0F0;
  --cat-dessert-bg: #D7C7F0;

  --cat-staple-fg:  #8A6B1E;
  --cat-veggie-fg:  #3F7A56;
  --cat-protein-fg: #8A4F25;
  --cat-soup-fg:    #2E5A82;
  --cat-dessert-fg: #5B4080;

  /* v2 状态色 */
  --status-on-time:    #5C8C72;
  --status-on-time-bg: rgba(200, 230, 217, 0.3);
  --status-late:       #B58A3F;
  --status-late-bg:    rgba(255, 217, 179, 0.3);
  --status-missed:     #6B89AD;
  --status-missed-bg:  rgba(214, 229, 245, 0.3);

  background: var(--color-bg);
  color: var(--color-text);
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Helvetica Neue', sans-serif;
  font-size: 28rpx;
  line-height: 1.6;
}

/* 通用容器 */
.container {
  min-height: 100vh;
  padding: 32rpx 28rpx;
  box-sizing: border-box;
}

/* 卡片 */
.card {
  background: var(--color-card);
  border-radius: var(--radius-md);
  padding: 32rpx;
  box-shadow: var(--shadow-card);
  margin-bottom: 24rpx;
}

.card-soft {
  background: linear-gradient(135deg, #FFFCF7 0%, #FFF4F6 100%);
  border-radius: var(--radius-lg);
  padding: 40rpx 32rpx;
  box-shadow: var(--shadow-soft);
}

/* 文字 */
.title {
  font-size: 40rpx;
  font-weight: 600;
  color: var(--color-text);
  letter-spacing: 1rpx;
}

.subtitle {
  font-size: 30rpx;
  color: var(--color-subtext);
  margin-top: 8rpx;
}

.text-muted {
  color: var(--color-subtext);
  font-size: 24rpx;
}

/* 圆角胶囊 */
.pill {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 12rpx 28rpx;
  border-radius: var(--radius-full);
  font-size: 26rpx;
  background: var(--color-primary-soft);
  color: var(--color-primary);
  margin-right: 12rpx;
  margin-bottom: 12rpx;
}

.pill-outline {
  background: transparent;
  border: 2rpx solid var(--color-primary-soft);
  color: var(--color-text);
}

.pill-mint {
  background: #E8F4ED;
  color: #5C8C72;
}

.pill-sky {
  background: #E8F0F8;
  color: #6B89AD;
}

.pill-lavender {
  background: #EFE9F5;
  color: #8B7AA8;
}

/* 分割线 */
.divider {
  height: 1rpx;
  background: rgba(0, 0, 0, 0.04);
  margin: 32rpx 0;
}

/* 浮动元素 */
.float-shadow {
  box-shadow: var(--shadow-float);
}

/* 通用 flex */
.flex {
  display: flex;
  align-items: center;
}

.flex-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}

.flex-col {
  display: flex;
  flex-direction: column;
}

.flex-1 { flex: 1; }

/* 按钮基础 */
.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-full);
  font-size: 30rpx;
  font-weight: 500;
  letter-spacing: 2rpx;
  border: none;
  padding: 24rpx 0;
  transition: all 0.2s;
}

.btn::after {
  border: none;
}

.btn-primary {
  background: linear-gradient(135deg, #FFB3C1 0%, #FF9FB0 100%);
  color: #fff;
  box-shadow: 0 6rpx 18rpx rgba(255, 159, 176, 0.4);
}

.btn-primary[disabled] {
  opacity: 0.5;
  box-shadow: none;
}

.btn-ghost {
  background: var(--color-primary-soft);
  color: var(--color-primary);
}

.btn-block {
  width: 100%;
}

/* 空状态 */
.empty {
  text-align: center;
  padding: 80rpx 32rpx;
  color: var(--color-subtext);
}

.empty-emoji {
  font-size: 96rpx;
  display: block;
  margin-bottom: 24rpx;
  filter: grayscale(0.2);
}

/* 标签云 */
.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

/* 头像 */
.avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: var(--color-pink);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  border: 4rpx solid #fff;
  box-shadow: var(--shadow-card);
}

.avatar-lg {
  width: 120rpx;
  height: 120rpx;
}

.avatar-sm {
  width: 56rpx;
  height: 56rpx;
  border-width: 2rpx;
}

.avatar image {
  width: 100%;
  height: 100%;
}

/* 头部 */
.page-header {
  padding: 48rpx 32rpx 24rpx;
}

.page-header .title {
  margin-bottom: 8rpx;
}

/* 页面切换动画 */
.page-enter {
  animation: fadeIn 0.4s ease;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(20rpx); }
  to { opacity: 1; transform: translateY(0); }
}

/* 数字 */
.num {
  font-feature-settings: "tnum";
  font-variant-numeric: tabular-nums;
}

/* ============================================
 * v3.1 · 5 大食物类别 tag（替代旧 10 个细粒度标签）
 * ============================================ */
.tag-cat {
  display: inline-flex;
  align-items: center;
  padding: 6rpx 18rpx;
  border-radius: var(--radius-full);
  font-size: 22rpx;
  font-weight: 500;
  margin-right: 10rpx;
  margin-bottom: 8rpx;
}
.tag-cat .emoji { margin-right: 6rpx; font-size: 22rpx; }
.tag-cat.cat-staple  { background: linear-gradient(135deg, #FFF4D6, #FFE7A0); color: var(--cat-staple-fg); }
.tag-cat.cat-veggie  { background: linear-gradient(135deg, #D6EBDC, #C6EBC9); color: var(--cat-veggie-fg); }
.tag-cat.cat-protein { background: linear-gradient(135deg, #FFE0CC, #FFC7A0); color: var(--cat-protein-fg); }
.tag-cat.cat-soup    { background: linear-gradient(135deg, #DCE8F4, #C7E0F0); color: var(--cat-soup-fg); }
.tag-cat.cat-dessert { background: linear-gradient(135deg, #E8DEF5, #D7C7F0); color: var(--cat-dessert-fg); }

/* ============================================
 * 状态徽章（按时 / 延时 / 缺卡）
 * ============================================ */
.status-badge {
  display: inline-flex;
  align-items: center;
  padding: 4rpx 16rpx;
  border-radius: var(--radius-full);
  font-size: 22rpx;
  font-weight: 500;
}
.status-badge.on-time { background: var(--status-on-time-bg); color: var(--status-on-time); }
.status-badge.late    { background: var(--status-late-bg);    color: var(--status-late); }
.status-badge.missed  { background: var(--status-missed-bg);  color: var(--status-missed); }

/* 必选徽章（v3.1 强化） */
.required-badge {
  display: inline-flex;
  align-items: center;
  padding: 2rpx 16rpx;
  border-radius: var(--radius-full);
  background: var(--color-primary-soft);
  color: var(--color-primary);
  font-size: 20rpx;
  font-weight: 600;
  margin-left: 12rpx;
}
