/* pages/camera/camera.wxss */
.page {
  min-height: 100vh;
  padding: 0 0 60rpx;
  background: var(--color-bg);
}

/* 顶部导航 */
.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  background: var(--color-bg);
  position: sticky;
  top: 0;
  z-index: 10;
}
.nav-back {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  color: var(--color-text);
  box-shadow: var(--shadow-card);
}
.nav-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text);
  letter-spacing: 2rpx;
}
.nav-placeholder { width: 60rpx; }

/* 照片区 */
.photo-card {
  margin: 24rpx 32rpx;
  background: #fff;
  border-radius: var(--radius-lg);
  padding: 24rpx;
  box-shadow: var(--shadow-card);
}
.photo-preview {
  width: 100%;
  height: 380rpx;
  border-radius: var(--radius-md);
  background: linear-gradient(135deg, #FFE3E8 0%, #E5D9F2 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-direction: column;
  position: relative;
  overflow: hidden;
}
.photo-emoji { font-size: 120rpx; }
.photo-tip {
  margin-top: 16rpx;
  font-size: 24rpx;
  color: var(--color-subtext);
  letter-spacing: 1rpx;
}
.photo-img {
  width: 100%;
  height: 100%;
}
.photo-repick {
  position: absolute;
  bottom: 16rpx;
  right: 16rpx;
  background: rgba(0, 0, 0, 0.5);
  color: #fff;
  padding: 8rpx 20rpx;
  border-radius: 9999rpx;
  font-size: 22rpx;
}
.photo-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
}
.photo-btn {
  flex: 1;
  background: var(--color-primary-soft);
  color: var(--color-primary);
  padding: 20rpx 0;
  border-radius: var(--radius-full);
  font-size: 26rpx;
  text-align: center;
  font-weight: 500;
  letter-spacing: 1rpx;
}
.photo-btn .ico { margin-right: 8rpx; }

/* 区域标题 */
.section-label {
  display: flex;
  align-items: center;
  padding: 24rpx 32rpx 16rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text);
  letter-spacing: 1rpx;
}
.section-label::before {
  content: '';
  width: 8rpx;
  height: 24rpx;
  border-radius: 4rpx;
  background: linear-gradient(135deg, #FFB3C1, #FF9FB0);
  margin-right: 12rpx;
}

/* 餐次 4 选 1 */
.meal-type-row {
  display: flex;
  gap: 12rpx;
  padding: 0 32rpx;
}
.meal-type {
  flex: 1;
  background: #fff;
  border: 2rpx solid transparent;
  border-radius: var(--radius-md);
  padding: 20rpx 8rpx;
  text-align: center;
  box-shadow: var(--shadow-card);
  transition: all 0.2s;
}
.meal-type .emoji { font-size: 40rpx; }
.meal-type .label {
  font-size: 24rpx;
  color: var(--color-text);
  margin-top: 4rpx;
  font-weight: 500;
}
.meal-type .deadline {
  font-size: 18rpx;
  color: var(--color-subtext);
  margin-top: 4rpx;
}
.meal-type.active {
  background: linear-gradient(135deg, #FFE3E8 0%, #FFD3DA 100%);
  border-color: var(--color-primary);
  transform: scale(1.02);
}

/* 正餐/速食 */
.main-cat-row {
  display: flex;
  gap: 20rpx;
  padding: 0 32rpx;
}
.main-cat {
  flex: 1;
  background: #fff;
  border: 2rpx solid transparent;
  border-radius: var(--radius-md);
  padding: 32rpx 0;
  text-align: center;
  box-shadow: var(--shadow-card);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}
.main-cat-emoji { font-size: 60rpx; }
.main-cat-label {
  font-size: 28rpx;
  color: var(--color-text);
  font-weight: 500;
}
.main-cat.active.meal {
  background: linear-gradient(135deg, #FFE3E8 0%, #FFD3DA 100%);
  border-color: var(--color-primary);
}
.main-cat.active.fast {
  background: linear-gradient(135deg, #FFE8D4 0%, #FFD9B3 100%);
  border-color: #FFB870;
}

/* 5 大食物类别 */
.food-cat-grid {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 12rpx;
  padding: 0 32rpx;
}
.food-cat {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  padding: 16rpx 4rpx;
  background: #F7F5F2;
  border-radius: 20rpx;
  border: 2rpx solid transparent;
  transition: all 0.2s;
}
.food-cat-emoji {
  font-size: 36rpx;
  filter: grayscale(0.4);
  opacity: 0.7;
}
.food-cat-name {
  font-size: 20rpx;
  color: var(--color-subtext);
  letter-spacing: 0.5rpx;
}
.food-cat.active.cat-staple {
  background: linear-gradient(135deg, #FFF4D6, #FFE7A0);
  border-color: #F0C95C;
  box-shadow: 0 4rpx 12rpx rgba(240, 201, 92, 0.25);
}
.food-cat.active.cat-veggie {
  background: linear-gradient(135deg, #D6EBDC, #C6EBC9);
  border-color: #7BC094;
  box-shadow: 0 4rpx 12rpx rgba(123, 192, 148, 0.25);
}
.food-cat.active.cat-protein {
  background: linear-gradient(135deg, #FFE0CC, #FFC7A0);
  border-color: #F0A36B;
  box-shadow: 0 4rpx 12rpx rgba(240, 163, 107, 0.25);
}
.food-cat.active.cat-soup {
  background: linear-gradient(135deg, #DCE8F4, #C7E0F0);
  border-color: #7AAED1;
  box-shadow: 0 4rpx 12rpx rgba(122, 174, 209, 0.25);
}
.food-cat.active.cat-dessert {
  background: linear-gradient(135deg, #E8DEF5, #D7C7F0);
  border-color: #B69FE0;
  box-shadow: 0 4rpx 12rpx rgba(182, 159, 224, 0.25);
}
.food-cat.active .food-cat-emoji {
  filter: grayscale(0);
  opacity: 1;
}
.food-cat.active .food-cat-name {
  color: var(--color-text);
  font-weight: 600;
}

/* 阈值提示 */
.threshold-hint {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  margin: 24rpx 32rpx;
  padding: 20rpx 24rpx;
  background: linear-gradient(135deg, #FFE8D4 0%, #FFD9B3 100%);
  border-radius: var(--radius-md);
  font-size: 24rpx;
  color: #8A5A1F;
  line-height: 1.6;
}
.threshold-hint-icon { font-size: 32rpx; flex-shrink: 0; }
.threshold-hint-text strong { color: #B58A3F; font-weight: 600; }

/* 备注 */
.note-area {
  margin: 0 32rpx;
  background: #fff;
  border-radius: var(--radius-md);
  padding: 20rpx;
  box-shadow: var(--shadow-card);
  position: relative;
}
.note-input {
  width: 100%;
  min-height: 100rpx;
  font-size: 26rpx;
  color: var(--color-text);
  line-height: 1.6;
}
.note-placeholder {
  color: var(--color-subtext);
}
.note-count {
  position: absolute;
  right: 24rpx;
  bottom: 16rpx;
  font-size: 22rpx;
  color: var(--color-subtext);
}

/* 提交按钮 */
.submit-btn {
  margin: 48rpx 32rpx 0;
  background: linear-gradient(135deg, #FFB3C1 0%, #FF9FB0 100%);
  color: #fff;
  text-align: center;
  padding: 28rpx 0;
  border-radius: var(--radius-full);
  font-size: 32rpx;
  font-weight: 600;
  letter-spacing: 4rpx;
  box-shadow: 0 6rpx 18rpx rgba(255, 159, 176, 0.4);
}
.submit-btn.disabled {
  background: #E5E5EA;
  color: #B0B0B8;
  box-shadow: none;
}

.safe-bottom {
  height: 60rpx;
}
