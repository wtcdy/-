/* pages/history/history.wxss */
.page {
  min-height: 100vh;
  background: var(--color-bg);
  padding-bottom: 200rpx;
}

.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  background: var(--color-bg);
  position: sticky;
  top: 0;
  z-index: 10;
}
.nav-back, .nav-placeholder {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  color: var(--color-text);
  box-shadow: var(--shadow-card);
}
.nav-placeholder { visibility: hidden; }
.nav-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text);
  letter-spacing: 2rpx;
}

/* 统计卡 */
.stat-card {
  display: flex;
  align-items: center;
  margin: 24rpx 32rpx;
  background: #fff;
  border-radius: var(--radius-lg);
  padding: 28rpx 16rpx;
  box-shadow: var(--shadow-card);
}
.stat-item {
  flex: 1;
  text-align: center;
}
.stat-num {
  font-size: 40rpx;
  font-weight: 600;
  color: var(--color-text);
  line-height: 1;
}
.stat-label {
  font-size: 22rpx;
  color: var(--color-subtext);
  margin-top: 8rpx;
}
.stat-divider {
  width: 2rpx;
  height: 60rpx;
  background: rgba(0, 0, 0, 0.05);
}

/* 空 */
.empty {
  text-align: center;
  padding: 200rpx 48rpx;
}
.empty-emoji {
  font-size: 120rpx;
  display: block;
  margin-bottom: 16rpx;
}
.empty-title {
  font-size: 32rpx;
  font-weight: 500;
  color: var(--color-text);
  margin-bottom: 8rpx;
}
.empty-sub {
  font-size: 24rpx;
  color: var(--color-subtext);
}

/* 日期分组 */
.date-group {
  margin: 0 32rpx 32rpx;
}
.date-group-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 26rpx;
  font-weight: 600;
  color: var(--color-text);
  margin-bottom: 16rpx;
  padding: 0 8rpx;
}
.date-group-count {
  font-size: 22rpx;
  color: var(--color-subtext);
  font-weight: 400;
}

/* Meal card */
.meal-card {
  display: flex;
  background: #fff;
  border-radius: var(--radius-md);
  padding: 24rpx 20rpx;
  box-shadow: var(--shadow-card);
  margin-bottom: 16rpx;
  border-left: 8rpx solid transparent;
  position: relative;
}
.meal-card.on-time { border-left-color: var(--status-on-time); }
.meal-card.late    { border-left-color: var(--status-late); }
.meal-card.missed  { border-left-color: var(--status-missed); }

.main-cat-badge {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  padding: 4rpx 12rpx;
  border-radius: 9999rpx;
  font-size: 20rpx;
  font-weight: 500;
}
.main-cat-badge.meal { background: #FFE3E8; color: #FF6B8B; }
.main-cat-badge.fast { background: #FFD9B3; color: #B58A3F; }

.card-left { margin-right: 20rpx; }
.card-thumb {
  width: 120rpx;
  height: 120rpx;
  border-radius: var(--radius-md);
  background: linear-gradient(135deg, #FFE3E8, #FFD3DA);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 56rpx;
  overflow: hidden;
}
.card-thumb-img { width: 100%; height: 100%; }
.card-thumb-emoji { font-size: 64rpx; }

.card-body {
  flex: 1;
  min-width: 0;
  padding-right: 100rpx;   /* 避让主分类徽章 */
}
.card-top { margin-bottom: 8rpx; }
.meal-name {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--color-text);
}
.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-bottom: 8rpx;
}
.record-note {
  font-size: 22rpx;
  color: var(--color-subtext);
  font-style: italic;
  margin: 8rpx 0;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.card-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 8rpx;
}
.pill-link {
  font-size: 22rpx;
  color: var(--color-primary);
}

/* Load more */
.load-more {
  text-align: center;
  padding: 24rpx 0;
}
.load-more-btn {
  display: inline-block;
  padding: 16rpx 48rpx;
  background: #fff;
  border-radius: 9999rpx;
  font-size: 24rpx;
  color: var(--color-primary);
  box-shadow: var(--shadow-card);
}
.load-end {
  text-align: center;
  font-size: 22rpx;
  color: var(--color-subtext);
  padding: 32rpx 0;
}

/* FAB */
.fab {
  position: fixed;
  right: 40rpx;
  bottom: 140rpx;
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FFB3C1, #FF9FB0);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  box-shadow: 0 8rpx 24rpx rgba(255, 159, 176, 0.5);
  z-index: 100;
}
.fab-icon { font-size: 56rpx; line-height: 1; font-weight: 300; }
