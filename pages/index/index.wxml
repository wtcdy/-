<view class="page">
  <!-- 自定义顶部 -->
  <view class="custom-nav">
    <view class="nav-greeting">
      <view class="greeting-line">{{greetingText}}</view>
      <view class="greeting-date">{{dateText}}</view>
    </view>
    <view class="nav-avatar" bindtap="onTapAvatar">
      <image wx:if="{{userInfo.avatarUrl}}" src="{{userInfo.avatarUrl}}" class="avatar-img"/>
      <text wx:else class="avatar-default">{{userInfo.nickName ? userInfo.nickName[0] : '我'}}</text>
    </view>
  </view>

  <!-- 周末提示 -->
  <view class="weekend-banner" wx:if="{{isWeekend}}">
    <text class="weekend-emoji">🌿</text>
    <view>
      <view class="weekend-title">今天是周末，好好休息～</view>
      <view class="weekend-sub">周末打卡仅展示，不计入周统计</view>
    </view>
  </view>

  <!-- 今日 3 餐次卡片 -->
  <view class="meals-card">
    <view class="meals-header">
      <text>今日打卡</text>
      <text class="meals-count">{{todayRecords.length}} 餐</text>
    </view>

    <!-- 餐次卡片（4 个：早/午/晚/加餐） -->
    <view class="meal-row">
      <view wx:for="{{mealSlots}}"
            wx:key="value"
            class="meal-slot {{item.status}}"
            data-slot="{{item}}"
            bindtap="onTapMealSlot">
        <view class="slot-emoji">{{item.emoji}}</view>
        <view class="slot-info">
          <view class="slot-label">{{item.label}}</view>
          <view class="slot-status">
            <text wx:if="{{item.status === 'on_time'}}" class="status-dot on-time"></text>
            <text wx:elif="{{item.status === 'late'}}" class="status-dot late"></text>
            <text wx:elif="{{item.status === 'missed'}}" class="status-dot missed"></text>
            <text wx:else class="status-dot pending"></text>
            <text class="status-text">{{item.statusText}}</text>
          </view>
        </view>
        <view class="slot-action">
          <text wx:if="{{item.record}}" class="slot-cta">查看 ›</text>
          <text wx:elif="{{item.status === 'pending'}}" class="slot-cta-mute">待开干</text>
          <text wx:else class="slot-cta">+ 打卡</text>
        </view>
      </view>
    </view>

    <!-- 空状态：今日无任何打卡 -->
    <view class="empty-state" wx:if="{{todayRecords.length === 0 && !isWeekend}}">
      <view class="empty-emoji">🍱</view>
      <view class="empty-title">今天还没有打卡</view>
      <view class="empty-sub">点上方餐次开始第一餐吧～</view>
    </view>
  </view>

  <!-- 本周小结快捷卡 -->
  <view class="week-summary-card" bindtap="onTapWeekSummary" wx:if="{{!isWeekend}}">
    <view class="wsc-left">
      <view class="wsc-range">{{weekStats.rangeText || '本周'}} · 工作日</view>
      <view class="wsc-line">
        <text class="wsc-num num">{{weekStats.onTimeRate || 0}}<text class="wsc-pct">%</text></text>
        <text class="wsc-num-label">按时率</text>
      </view>
      <view class="wsc-sub">已打卡 {{weekStats.daysPassed || 0}} / 5 工作日</view>
    </view>
    <view class="wsc-right">
      <view class="wsc-pill">正餐 {{weekStats.mealRate || 0}}%</view>
      <view class="wsc-arrow">›</view>
    </view>
  </view>

  <!-- 浮动打卡按钮 -->
  <view class="fab" bindtap="onTapFab">
    <text class="fab-icon">+</text>
    <text class="fab-text">打卡</text>
  </view>
</view>
