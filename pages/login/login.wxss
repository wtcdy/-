.login-page {
  min-height: 100vh;
  padding: 80rpx 48rpx 48rpx;
  position: relative;
  overflow: hidden;
  background: linear-gradient(180deg, #FFFCF7 0%, #FFF0F2 50%, #FFFCF7 100%);
}

/* 飘浮气泡 */
.bubble {
  position: absolute;
  border-radius: 50%;
  filter: blur(8rpx);
  opacity: 0.5;
  animation: float 8s ease-in-out infinite;
}
.bubble-1 {
  width: 200rpx; height: 200rpx;
  background: var(--color-pink);
  top: 5%; right: -40rpx;
  animation-delay: 0s;
}
.bubble-2 {
  width: 160rpx; height: 160rpx;
  background: var(--color-mint);
  top: 35%; left: -50rpx;
  animation-delay: 2s;
}
.bubble-3 {
  width: 240rpx; height: 240rpx;
  background: var(--color-lavender);
  bottom: 10%; right: -60rpx;
  animation-delay: 4s;
}

@keyframes float {
  0%, 100% { transform: translate(0, 0); }
  50% { transform: translate(0, -30rpx); }
}

.logo-wrap {
  text-align: center;
  margin: 60rpx 0 60rpx;
  position: relative;
  z-index: 1;
}

.logo-circle {
  width: 160rpx;
  height: 160rpx;
  margin: 0 auto 32rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FFB3C1 0%, #FFD3DA 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 16rpx 40rpx rgba(255, 159, 176, 0.4);
}

.logo-emoji {
  font-size: 80rpx;
  filter: drop-shadow(0 4rpx 8rpx rgba(0,0,0,0.1));
}

.logo-name {
  font-size: 56rpx;
  font-weight: 600;
  color: var(--color-text);
  letter-spacing: 4rpx;
  margin-bottom: 12rpx;
}

.logo-slogan {
  font-size: 26rpx;
  color: var(--color-subtext);
  letter-spacing: 2rpx;
}

.privacy-card {
  margin: 48rpx 0;
  position: relative;
  z-index: 1;
}

.title-sm {
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.subtitle-sm {
  font-size: 24rpx;
  color: var(--color-subtext);
  margin-bottom: 24rpx;
}

.bullet {
  display: flex;
  align-items: center;
  font-size: 26rpx;
  color: var(--color-text);
  margin-bottom: 12rpx;
}

.dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: var(--color-primary);
  margin-right: 16rpx;
}

.auth-area {
  position: relative;
  z-index: 1;
}

.profile-row {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 9999rpx;
  padding: 12rpx 16rpx 12rpx 12rpx;
  margin-bottom: 32rpx;
  box-shadow: var(--shadow-card);
}

.avatar-btn {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FFE3E8 0%, #FFD3DA 100%);
  border: none;
  margin: 0;
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.avatar-btn::after {
  border: none;
}

.avatar-img {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.avatar-placeholder {
  font-size: 48rpx;
  color: #fff;
  font-weight: 200;
  line-height: 1;
}

.nickname-input {
  flex: 1;
  margin-left: 24rpx;
  font-size: 28rpx;
  color: var(--color-text);
}

.agreement {
  display: flex;
  align-items: flex-start;
  font-size: 24rpx;
  color: var(--color-subtext);
  margin-bottom: 32rpx;
  line-height: 1.5;
}

.agreement checkbox-group {
  margin-right: 8rpx;
  transform: scale(0.8);
  transform-origin: left center;
}

.link {
  color: var(--color-primary);
}

.login-btn {
  width: 100%;
  font-size: 32rpx;
  font-weight: 500;
  letter-spacing: 4rpx;
}

.footer-tip {
  margin-top: 64rpx;
  text-align: center;
  font-size: 22rpx;
  color: var(--color-subtext);
  letter-spacing: 1rpx;
  opacity: 0.7;
  position: relative;
  z-index: 1;
}
