/* pages/pair/pair.wxss */
.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #FFFCF7 0%, #FFF0F2 100%);
  position: relative;
  overflow: hidden;
}

.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  position: relative;
  z-index: 2;
}
.nav-back, .nav-placeholder {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  color: var(--color-text);
  box-shadow: var(--shadow-card);
}
.nav-placeholder { visibility: hidden; }
.nav-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text);
  letter-spacing: 2rpx;
}

/* 飘浮气泡 */
.bubble {
  position: absolute;
  border-radius: 50%;
  filter: blur(20rpx);
  opacity: 0.4;
  pointer-events: none;
}
.bubble-1 {
  width: 280rpx;
  height: 280rpx;
  background: var(--color-pink);
  top: 15%;
  right: -80rpx;
}
.bubble-2 {
  width: 220rpx;
  height: 220rpx;
  background: var(--color-lavender);
  bottom: 10%;
  left: -60rpx;
}

/* Tab */
.pair-tab {
  display: flex;
  margin: 24rpx 64rpx;
  background: rgba(255, 255, 255, 0.6);
  border-radius: 9999rpx;
  padding: 8rpx;
  position: relative;
  z-index: 2;
}
.pair-tab-item {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 26rpx;
  color: var(--color-subtext);
  border-radius: 9999rpx;
  transition: all 0.2s;
}
.pair-tab-item.active {
  background: #fff;
  color: var(--color-primary);
  font-weight: 600;
  box-shadow: var(--shadow-card);
}

.pair-content {
  position: relative;
  z-index: 2;
  padding: 32rpx;
}

/* 插画 */
.pair-illu {
  text-align: center;
  padding: 40rpx 0;
}
.pair-illu-emoji {
  font-size: 120rpx;
  display: block;
  margin-bottom: 16rpx;
}
.pair-illu-title {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--color-text);
  letter-spacing: 2rpx;
}
.pair-illu-sub {
  font-size: 24rpx;
  color: var(--color-subtext);
  margin-top: 12rpx;
  line-height: 1.6;
}

/* 配对码展示 */
.code-card {
  background: #fff;
  border-radius: var(--radius-lg);
  padding: 40rpx 32rpx;
  text-align: center;
  box-shadow: var(--shadow-card);
  margin: 32rpx 0;
}
.code-label {
  font-size: 24rpx;
  color: var(--color-subtext);
  margin-bottom: 20rpx;
  letter-spacing: 1rpx;
}
.code-display {
  display: flex;
  justify-content: center;
  gap: 16rpx;
  margin: 24rpx 0;
}
.code-digit {
  width: 80rpx;
  height: 100rpx;
  background: linear-gradient(135deg, #FFE3E8 0%, #FFD3DA 100%);
  color: var(--color-primary);
  font-size: 48rpx;
  font-weight: 700;
  border-radius: var(--radius-md);
  display: flex;
  align-items: center;
  justify-content: center;
  letter-spacing: 0;
}
.code-timer {
  font-size: 28rpx;
  color: #B58A3F;
  font-weight: 500;
  margin: 16rpx 0;
}
.code-tip {
  font-size: 22rpx;
  color: var(--color-subtext);
  margin-top: 16rpx;
  line-height: 1.6;
}

/* 输入配对码 */
.input-row {
  display: flex;
  justify-content: center;
  gap: 16rpx;
  margin: 48rpx 0 60rpx;
}
.code-input {
  width: 80rpx;
  height: 100rpx;
  background: #fff;
  border: 2rpx solid #E5E5EA;
  border-radius: var(--radius-md);
  text-align: center;
  font-size: 44rpx;
  font-weight: 600;
  color: var(--color-text);
  box-shadow: var(--shadow-card);
}
.code-input.filled {
  border-color: var(--color-primary);
  background: linear-gradient(135deg, #FFE3E8 0%, #FFD3DA 100%);
  color: var(--color-primary);
}

/* CTA */
.pair-cta {
  background: linear-gradient(135deg, #FFB3C1, #FF9FB0);
  color: #fff;
  padding: 28rpx 0;
  border-radius: var(--radius-full);
  text-align: center;
  font-size: 30rpx;
  font-weight: 600;
  letter-spacing: 4rpx;
  box-shadow: 0 6rpx 18rpx rgba(255, 159, 176, 0.4);
  margin-top: 24rpx;
}
.pair-cta.ghost {
  background: #fff;
  color: var(--color-primary);
  border: 2rpx solid var(--color-primary-soft);
  box-shadow: none;
}
