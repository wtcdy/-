/* pages/partner/partner.wxss */
.page {
  min-height: 100vh;
  background: var(--color-bg);
  padding-bottom: 60rpx;
}

/* 头部 */
.header {
  position: relative;
  padding: 0 0 60rpx;
  margin-bottom: 32rpx;
}
.header-bg {
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 380rpx;
  background: linear-gradient(135deg, #FFE3E8 0%, #E5D9F2 50%, #D6E5F5 100%);
  border-bottom-left-radius: 60rpx;
  border-bottom-right-radius: 60rpx;
  z-index: 0;
}
.header-content {
  position: relative;
  z-index: 1;
  text-align: center;
  padding: 60rpx 32rpx 0;
}
.avatar-lg {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto;
  overflow: hidden;
  border: 6rpx solid #fff;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.1);
}
.avatar-img { width: 100%; height: 100%; }
.avatar-default {
  font-size: 64rpx;
  color: var(--color-primary);
  font-weight: 600;
}
.header-name {
  font-size: 40rpx;
  font-weight: 600;
  color: var(--color-text);
  margin-top: 20rpx;
  letter-spacing: 2rpx;
}
.header-paired {
  font-size: 24rpx;
  color: var(--color-subtext);
  margin-top: 8rpx;
}

/* 空状态 */
.empty-wrap {
  text-align: center;
  padding: 200rpx 48rpx;
}
.empty-emoji {
  font-size: 120rpx;
  display: block;
  margin-bottom: 24rpx;
}
.empty-title {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--color-text);
  margin-bottom: 12rpx;
}
.empty-sub {
  font-size: 24rpx;
  color: var(--color-subtext);
  margin-bottom: 48rpx;
  line-height: 1.6;
}
.empty-cta {
  display: inline-block;
  background: linear-gradient(135deg, #FFB3C1, #FF9FB0);
  color: #fff;
  padding: 24rpx 60rpx;
  border-radius: var(--radius-full);
  font-size: 28rpx;
  font-weight: 600;
  letter-spacing: 2rpx;
  box-shadow: 0 6rpx 18rpx rgba(255, 159, 176, 0.4);
}

/* 5 工作日 */
.week-card {
  margin: 0 32rpx 32rpx;
  background: #fff;
  border-radius: var(--radius-lg);
  padding: 28rpx 24rpx;
  box-shadow: var(--shadow-card);
}
.week-header {
  display: flex;
  justify-content: space-between;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text);
  margin-bottom: 24rpx;
}
.week-range { font-size: 22rpx; color: var(--color-subtext); font-weight: 400; }
.week-grid {
  display: flex;
  justify-content: space-between;
}
.week-day {
  flex: 1;
  text-align: center;
}
.day-name {
  font-size: 22rpx;
  color: var(--color-subtext);
  margin-bottom: 12rpx;
}
.day-dot {
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  margin: 0 auto 8rpx;
  background: #E5E5EA;
}
.day-dot.on-time { background: var(--status-on-time); }
.day-dot.late    { background: var(--status-late); }
.day-dot.missed  { background: var(--status-missed); }
.day-dot.partial {
  background: repeating-conic-gradient(var(--status-on-time) 0% 50%, #E5E5EA 50% 100%);
  border-radius: 50%;
}
.day-date {
  font-size: 20rpx;
  color: var(--color-subtext);
}

/* Section */
.section {
  margin: 0 32rpx 32rpx;
}
.section-title {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text);
  margin-bottom: 16rpx;
  padding: 0 8rpx;
}
.section-count {
  font-size: 22rpx;
  color: var(--color-subtext);
  font-weight: 400;
}

.empty-mini {
  text-align: center;
  padding: 60rpx 0;
  color: var(--color-subtext);
  font-size: 24rpx;
}

/* Meal card */
.meal-card {
  display: flex;
  background: #fff;
  border-radius: var(--radius-md);
  padding: 20rpx;
  box-shadow: var(--shadow-card);
  margin-bottom: 16rpx;
  border-left: 8rpx solid transparent;
  position: relative;
}
.meal-card.on-time { border-left-color: var(--status-on-time); }
.meal-card.late    { border-left-color: var(--status-late); }
.meal-card.missed  { border-left-color: var(--status-missed); }

.card-left { margin-right: 20rpx; }
.card-thumb {
  width: 100rpx;
  height: 100rpx;
  border-radius: var(--radius-md);
  background: linear-gradient(135deg, #FFE3E8, #FFD3DA);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  overflow: hidden;
}
.card-thumb-img { width: 100%; height: 100%; }
.card-thumb-emoji { font-size: 56rpx; }

.card-body { flex: 1; min-width: 0; }
.card-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8rpx;
}
.meal-name {
  font-size: 26rpx;
  font-weight: 500;
  color: var(--color-text);
}
.main-cat-pill {
  padding: 2rpx 12rpx;
  border-radius: 9999rpx;
  font-size: 20rpx;
  font-weight: 500;
}
.main-cat-pill.meal { background: #FFE3E8; color: #FF6B8B; }
.main-cat-pill.fast { background: #FFD9B3; color: #B58A3F; }

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-bottom: 8rpx;
}
.card-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.like-btn {
  font-size: 22rpx;
  color: var(--color-primary);
  padding: 4rpx 16rpx;
  border-radius: 9999rpx;
  background: var(--color-primary-soft);
}

.unbind-link {
  text-align: center;
  font-size: 22rpx;
  color: var(--color-subtext);
  margin-top: 48rpx;
  letter-spacing: 1rpx;
  text-decoration: underline;
}
